# Copy this file to `.env`, fill the values, then run:
# bash scripts/install_cron.sh

# Required Telegram settings. Use a dedicated bot token for EGX News Bot.
# Public vote buttons cannot be collected if another app also polls this token.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Required AI settings for production mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=low

# AI is the default production analyzer. Use `rules` only for debugging.
EGX_NEWS_BOT_ANALYSIS_MODE=ai

# Alert filtering defaults.
EGX_NEWS_BOT_LIMIT=20
EGX_NEWS_BOT_MIN_STRENGTH=65
EGX_NEWS_BOT_MAX_AGE_HOURS=72
EGX_NEWS_BOT_INCLUDE_REVIEW=false

# Telegram public vote storage.
# Leave EGX_NEWS_BOT_FEEDBACK_DB blank to use egx_news_bot/data/feedback.sqlite3.
EGX_NEWS_BOT_FEEDBACK_DB=
EGX_NEWS_BOT_FEEDBACK_TIMEOUT=0

# Cron default: poll every 5 minutes.
EGX_NEWS_BOT_CRON_INTERVAL=5

# Optional PM2 loop interval override, in seconds. Leave blank to use EGX_NEWS_BOT_CRON_INTERVAL.
EGX_NEWS_BOT_PM2_INTERVAL_SECONDS=
